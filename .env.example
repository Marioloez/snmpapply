# Copia este archivo a .env (está en .gitignore) y completa los valores reales.
# Las variables del entorno real tienen prioridad sobre estas.

# Credenciales SSH por defecto, usadas cuando un dispositivo no las sobreescribe.
SSH_USER=cambiame
SSH_PASSWORD=cambiame

# Comunidad de lectura SNMPv2c que se aplica a los dispositivos.
SNMP_COMMUNITY=cambiame

# Opcional: puerto SSH por defecto (si se omite, 22).
# SSH_PORT=22

# Opcional: contraseñas con nombre, referenciadas por dispositivo mediante
# "password_env" en inventory.json (para sitios con credenciales distintas).
# PASS_MOON=cambiame
# PASS_HYATT=cambiame
