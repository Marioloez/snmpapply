# Copia este archivo a .env (está en .gitignore) y completa los valores reales.
# Las variables del entorno real tienen prioridad sobre estas.

# Usuario y contraseña SSH para acceder a los switches.
SSH_USER=cambiame
SSH_PASSWORD=cambiame

# Comunidad de lectura SNMPv2c que se aplica a los dispositivos.
SNMP_COMMUNITY=cambiame

# Opcional: puerto SSH (si se omite, 22).
# SSH_PORT=22
